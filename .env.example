# MONO — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file with real credentials.

# ===========================
# App Configuration
# ===========================
NEXT_PUBLIC_APP_NAME="MONO"
NEXT_PUBLIC_APP_VERSION="0.1.0"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================
# Feature Flags
# ===========================
# Set to "true" to enable experimental features
NEXT_PUBLIC_ENABLE_DEVTOOLS="false"

# ===========================
# Database (Phase 3 — Backend)
# Not used in Phase 1 (local-first, no backend)
# ===========================
# DATABASE_URL="postgresql://user:password@localhost:5432/mono"
# DATABASE_POOL_MIN="2"
# DATABASE_POOL_MAX="10"

# ===========================
# Authentication (Phase 3)
# ===========================
# AUTH_SECRET="generate-with: openssl rand -base64 32"
# AUTH_URL="http://localhost:3000"

# ===========================
# Redis Cache (Phase 3)
# ===========================
# REDIS_URL="redis://localhost:6379"

# ===========================
# WebSocket Server (Phase 3)
# ===========================
# WS_SERVER_URL="ws://localhost:3001"

# ===========================
# Object Storage (Phase 2+)
# ===========================
# STORAGE_ENDPOINT=""
# STORAGE_ACCESS_KEY=""
# STORAGE_SECRET_KEY=""
# STORAGE_BUCKET=""
