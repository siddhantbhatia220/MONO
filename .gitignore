# MONO — .gitignore
# Production-grade gitignore for a Next.js TypeScript project

# ===========================
# Dependencies
# ===========================
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ===========================
# Next.js Build Output
# ===========================
.next/
out/
build/
dist/

# ===========================
# Environment Variables
# NEVER commit .env files
# ===========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ===========================
# Logs
# ===========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ===========================
# Testing & Coverage
# ===========================
coverage/
.nyc_output/
.jest-cache/

# ===========================
# TypeScript
# ===========================
*.tsbuildinfo
next-env.d.ts
.claude/
CLAUDE.md
agents.md
AGENTS.md
.agents/
.ai/
decisions/
scripts/
scratch/